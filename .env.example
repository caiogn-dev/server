# ============================================================================
# PASTITA PLATFORM - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# =============================================================================
# DJANGO CORE
# =============================================================================
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-in-production-min-50-chars-long-key-here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*.railway.app

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# For local development with Docker:
DATABASE_URL=postgresql://postgres:postgres@db:5432/pastita

# For Railway (auto-provided):
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# =============================================================================
# REDIS (Cache + Celery Broker)
# =============================================================================
# For local development with Docker:
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# For Railway (auto-provided):
# REDIS_URL=${{Redis.REDIS_URL}}
# CELERY_BROKER_URL=${{Redis.REDIS_URL}}
# CELERY_RESULT_BACKEND=${{Redis.REDIS_URL}}

# =============================================================================
# LANGCHAIN AI (Native - sem Langflow)
# =============================================================================
# AI / LLM Providers
# Configure apenas o provider que você usa. O agente lê a key do campo
# api_key no Django Admin (prioritário) ou das variáveis abaixo como fallback.
# =============================================================================

# NVIDIA NIM (provider atual — Caio usa meta/llama-3.1-405b-instruct)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=meta/llama-3.1-405b-instruct

# Kimi API (Moonshot)
KIMI_API_KEY=sk-kimi-xxx-your-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL_NAME=kimi-for-coding

# OpenAI (opcional)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini

# Anthropic (opcional)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_NAME=claude-3-5-sonnet-20241022

# Ollama (local - opcional)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_NAME=llama3.2

# =============================================================================
# MERCADO PAGO (Payments)
# =============================================================================
# Sandbox
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxx
MERCADO_PAGO_PUBLIC_KEY=TEST-xxx

# Production (use these in production)
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxx
# MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxx

MERCADO_PAGO_WEBHOOK_SECRET=

# =============================================================================
# INSTAGRAM / FACEBOOK
# =============================================================================
# Obtenha em: https://developers.facebook.com/apps/ → seu app → Configurações básicas
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Meta Pixel / Conversions API
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=
META_CAPI_VERSION=v25.0
META_CAPI_STORE_SLUGS=ce-saladas

# URL do frontend (dashboard) — usada para redirecionar após OAuth callback
FRONTEND_URL=https://pastita.com.br

# =============================================================================
# WHATSAPP BUSINESS API
# =============================================================================
WHATSAPP_WEBHOOK_VERIFY_TOKEN=seu-token-de-verificacao-webhook
WHATSAPP_ENABLE_LLM_FALLBACK=false
WHATSAPP_FORCE_DISABLE_LLM=false

# Store default fallback (used by automation when account context has no store)
DEFAULT_STORE_SLUG=pastita

# WebSocket origin policy
# In development you can keep true; in production keep false and set WEBSOCKET_ALLOWED_ORIGINS
WEBSOCKET_ALLOW_ALL_ORIGINS=false
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_xxx
DEFAULT_FROM_EMAIL=noreply@pastita.com

# =============================================================================
# MEDIA STORAGE
# =============================================================================
# Default: local filesystem + /media/ served by nginx/Django
USE_S3=false
SERVE_MEDIA_FILES=true
MEDIA_URL=/media/

# Optional: base URL for menu seed images if you want scripts to point to your own media host.
# Example local API:
# STORE_SEED_MEDIA_BASE_URL=https://backend.seudominio.com/media/seeds
STORE_SEED_MEDIA_BASE_URL=

# Legacy AWS S3 support (disabled unless USE_S3=true)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# SECURITY & CORS
# =============================================================================
# Set to False in production
DEBUG=True

# SSL/TLS
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# CORS - Additional origins allowed (comma-separated)
# These are added to the default list in settings
CORS_ALLOWED_ORIGINS=https://seu-dash.vercel.app,https://seu-outro-dominio.com
CSRF_TRUSTED_ORIGINS=https://backend.pastita.com.br

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=

# =============================================================================
# RAILWAY SPECIFIC
# =============================================================================
# These are automatically set by Railway
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=web
# PORT=8000
